{{ 'banner-custom.css' | asset_url | stylesheet_tag }}

<section class="banner-custom"
  style="background-image: url({{ section.settings.bg_image | image_url }});">

  <div class="banner-content">

    <h1>{{ section.settings.heading }}</h1>

    <p>{{ section.settings.text }}</p>

    <div class="multi-buttons">

  {% for block in section.blocks %}
    <a href="{{ block.settings.button_link }}" class="btn" {{ block.shopify_attributes }}>
      
      {% if block.settings.icon_position == 'left' %}
        <img src="{{ block.settings.icon | image_url }}" class="btn-icon">
      {% endif %}

      <span>{{ block.settings.button_text }}</span>

      {% if block.settings.icon_position == 'right' %}
        <img src="{{ block.settings.icon | image_url }}" class="btn-icon">
      {% endif %}

    </a>
  {% endfor %}

</div>

  </div>

</section>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Add your description here"
    },
    {
      "type": "text",
      "id": "button_text_one",
      "label": "Button Text One",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link_one",
      "label": "Button Link One"
    }
    {
  "type": "image_picker",
  "id": "icon_one",
  "label": "Button Icon One"
},
{
  "type": "select",
  "id": "icon_position_one",
  "label": "Icon Position One",
  "default": "right",
  "options": [
    { "value": "left", "label": "Left" },
    { "value": "right", "label": "Right" }
  ]
}
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}